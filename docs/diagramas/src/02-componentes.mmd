flowchart TB
    App["App<br/>(HashRouter + Routes)"]
    Layout["Layout<br/>(Header + Footer + Outlet)"]
    Header["Header<br/>(navegação + acessibilidade + Modal)"]
    Footer["Footer"]
    BotoesA["BotoesAcessibilidade"]
    Modal["Modal<br/>(confirmação genérica)"]

    App --> Layout
    Layout --> Header
    Layout --> Footer
    Header --> BotoesA
    Header --> Modal

    Home["Home"]
    Selecao["SelecaoEtapa"]
    Etapa["Etapa<br/>(carrega JSON ou componente)"]
    Atividades["Atividades<br/>(quizzes da etapa)"]
    Metronomo["Metronomo<br/>(rota standalone)"]
    NotFound["NotFound"]

    Layout --> Home
    Layout --> Selecao
    Layout --> Etapa
    Layout --> Atividades
    Layout --> Metronomo
    Layout --> NotFound

    Etapa --> CompassoEstatico["CompassoEstatico<br/>(Etapa 3 pág. 1–7)"]
