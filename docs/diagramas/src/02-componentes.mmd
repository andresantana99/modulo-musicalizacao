    Etapa --> MetronomoInline["MetronomoInline<br/>(Etapa 3 pág. 9)"]
    Etapa --> Conteudo["Conteúdo HTML<br/>(via getPagina)"]

    Atividades --> Quiz["QuizPergunta"]
    Metronomo --> MetronomoVisual

    CompassoEstatico --> Legenda["LegendaFiguras"]
