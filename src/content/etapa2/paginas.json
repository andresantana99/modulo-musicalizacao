[
  {
    "pagina": 1,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3\" style=\"min-height: 400px; margin: auto;\">\r\n    <div class=\"text-center pt-3\">\r\n        <p class=\"fs-4 fw-bold\">A bateria é formada por alguns elementos básicos, vamos conhecê-los.</p>\r\n        <br>\r\n        <br>\r\n    </div>\r\n\r\n</div>"
  },
  {
    "pagina": 2,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Primeiro vamos conhecer o chimbal, ilustrado abaixo:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-50\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/chimbal.png\"\r\n                            style=\"max-width: 100%;\" width=\"650\" height=\"350\" alt=\"Chimbal em notação musical\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n        <div class=\"text-center\">\r\n            <p class=\"fs-6\">Fonte: imagem gerada com a inteligência artificial Gemini do Google.</p>\r\n        </div>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 3,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">O segundo elemento básico é a Caixa, ilustrada abaixo:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-50\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/caixa.png\" style=\"max-width: 100%;\" width=\"650\"\r\n                            height=\"350\" alt=\"Caixa em notação musical\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n        <div class=\"text-center\">\r\n            <p class=\"fs-6\">Fonte: imagem gerada com a inteligência artificial Gemini do Google.</p>\r\n        </div>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 4,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Agora vamos conhecer o Bumbo, ilustrado abaixo:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-50\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/bumbo.png\" style=\"max-width: 100%;\" width=\"650\"\r\n                            height=\"350\" alt=\"Bumbo em notação musical\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n        <div class=\"text-center\">\r\n            <p class=\"fs-6\">Fonte: imagem gerada com a inteligência artificial Gemini do Google.</p>\r\n        </div>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 5,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3\" style=\"min-height: 400px; margin: auto;\">\r\n    <div class=\"text-center pt-3\">\r\n        <p class=\"fs-4 fw-bold\">Depois veremos outros elementos. Mas, agora iremos enfatizar como identificá-los em notação musical.</p>\r\n        <br>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 6,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3\" style=\"min-height: 400px; margin: auto;\">\r\n    <div class=\"text-center pt-3\">\r\n        <p class=\"fs-4 fw-bold\">Depois veremos outros elementos. Mas, agora iremos enfatizar em como identificá-los em\r\n            notação musical.</p>\r\n        <br>\r\n        <p class=\"fs-4\">As partituras musicais se baseiam no uso da pauta ou pentagrama. A pauta é formada por cinco linhas e quatro espaços. Veja a ilustração abaixo:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 120% !important;\"><img src=\"{{BASE}}img/pauta0.png\" style=\"max-width: 100%;\"\r\n                            alt=\"Pauta ou Pentagrama\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 7,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">A contagem de linhas é realizada de baixo para cima. Confira:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/pauta1.png\"\r\n                            style=\"max-width: 100%;\" alt=\"Primeira linha da pauta\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 8,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">A contagem de linhas é realizada de baixo para cima. Confira:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/pauta2.png\" style=\"max-width: 100%;\"\r\n                            alt=\"Segunda linha da pauta\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 9,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">A contagem de linhas é realizada de baixo para cima. Confira:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/pauta3.png\" style=\"max-width: 100%;\"\r\n                            alt=\"Terceira linha da pauta\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 10,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">A contagem de linhas é realizada de baixo para cima. Confira:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/pauta4.png\" style=\"max-width: 100%;\"\r\n                            alt=\"Quarta linha da pauta\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 11,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">A contagem de linhas é realizada de baixo para cima. Confira:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/pauta5.png\" style=\"max-width: 100%;\"\r\n                            alt=\"Quinta linha da pauta\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 12,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Cada linha e cada espaço indica uma nota musical. A referência para cada som é definida pela clave utilizada na partitura.</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-50\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                   \r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 13,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Contudo, no contexto de bateria e instrumentos percussivos, não emitimos notas musicais como dó, ré ou mi. Na verdade, precisamos saber qual elemento da bateria ou da percussão será atacado e qual a duração do som emitido.</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-50\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    \r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 14,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Por isso, em partitura para bateria ou percussão, utilizamos uma clave neutra. Ela é indicada pela figura abaixo:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-50\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/clave_neutra.png\" style=\"max-width: 100%;\"\r\n                            alt=\"Clave neutra no pentagrama\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 15,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Embora, as posições no pentagrama com uso da clave neutra não indiquem notas específicas, a ideia de notas graves e agudas se mantém.</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-50\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    \r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 16,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Ou seja, os elementos que emitem sons mais graves devem ser posicionados mais abaixo na pauta.</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-50\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    \r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 17,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Se compararmos os elementos Bumbo, Caixa e Chimbal, temos que o Bumbo é o que emite sons mais graves. Por isso, na pauta ou pentagrama, ele fica indicado na posição mais baixa. Veja este exemplo:</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/imag1_etapa2.png\" style=\"max-width: 100%;\"\r\n                            alt=\"\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 18,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Agora, vamos circular a posição do Bumbo neste exemplo (no espaço entre as linhas 1 e 2):</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/imag2_etapa2.png\" style=\"max-width: 100%;\"\r\n                            alt=\"\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 19,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Novamente, comparando os elementos básicos, o som emitido pela Caixa é mais agudo que o do Bumbo e mais grave que o do Chimbal.</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 20,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Então, analisando a imagem abaixo, você consegue identificar a posição da Caixa na partitura?</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/imag3_etapa2.png\" style=\"max-width: 100%;\"\r\n                            alt=\"\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 21,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">A seguir, a posição da Caixa está circulada neste exemplo (no espaço entre as linhas 3 e 4):</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/imag4_etapa2.png\" style=\"max-width: 100%;\"\r\n                            alt=\"\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 22,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Seguindo a mesma ideia, comparando os elementos básicos, o som emitido pelo Chimbal é o mais agudo em relação a Bumbo e Caixa.</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 23,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">Então, analisando a imagem abaixo, você consegue identificar a posição do Chimbal na partitura?</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/imag5_etapa2.png\" style=\"max-width: 100%;\"\r\n                            alt=\"\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
  {
    "pagina": 24,
    "html": "<div class=\"row p-3 mb-4 bg-body-tertiary rounded-3 text-center\" style=\"min-height: 300px; margin: auto;\">\r\n    <div class=\"text-center\">\r\n        <p class=\"fs-4\">A seguir, a posição do Chimbal está circulada neste exemplo (no espaço logo após a linha 5).</p>\r\n        <br>\r\n    </div>\r\n    <div class=\"table-responsive text-center margin-auto\">\r\n        <table class=\"table table-bordered border-light w-100\" style=\"margin: auto;\">\r\n            <thead>\r\n            </thead>\r\n            <tbody>\r\n                <tr>\r\n                    <td style=\"width: 100% !important;\"><img src=\"{{BASE}}img/imag6_etapa2.png\" style=\"max-width: 100%;\"\r\n                            alt=\"\" /></td>\r\n                </tr>\r\n            </tbody>\r\n        </table>\r\n        <br>\r\n    </div>\r\n</div>"
  },
